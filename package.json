{
  "name": "software-design-class",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A forum application built with concept design, running on Bun.",
  "scripts": {
    "start": "bun run src/main.ts",
    "example-client": "bun run example-client/server.ts",
    "test": "BCRYPT_ROUNDS=4 bun test src/",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:all": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "marked": "^18.0.4",
    "mongodb": "^7.2.0",
    "sanitize-html": "^2.17.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.3.14",
    "@types/sanitize-html": "^2.16.1",
    "mongodb-memory-server": "^11.2.0",
    "typescript": "^5.9.0"
  }
}
